<Window x:Class="FactumIL.Desktop.RecoveryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Factum IL — מצב שחזור"
        Height="400" Width="520"
        MinHeight="400" MinWidth="520"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0E1629"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="True">

  <Window.Resources>
    <!-- Gold accent colour used across the app -->
    <SolidColorBrush x:Key="GoldBrush"       Color="#C9A94F"/>
    <SolidColorBrush x:Key="LightTextBrush"  Color="#E8D9B5"/>
    <SolidColorBrush x:Key="PanelBrush"      Color="#1A2340"/>
    <SolidColorBrush x:Key="ErrorBrush"      Color="#EF5350"/>
    <SolidColorBrush x:Key="WarningBrush"    Color="#FFA726"/>
    <SolidColorBrush x:Key="BorderBrush"     Color="#C9A94F"/>

    <!-- Shared button style -->
    <Style x:Key="ActionButton" TargetType="Button">
      <Setter Property="FontFamily"        Value="Segoe UI"/>
      <Setter Property="FontSize"          Value="13"/>
      <Setter Property="Height"            Value="34"/>
      <Setter Property="Margin"            Value="6,0,0,0"/>
      <Setter Property="Padding"           Value="16,0"/>
      <Setter Property="Cursor"            Value="Hand"/>
      <Setter Property="BorderThickness"   Value="1"/>
      <Setter Property="Background"        Value="#1A2340"/>
      <Setter Property="Foreground"        Value="#E8D9B5"/>
      <Setter Property="BorderBrush"       Value="#C9A94F"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#253050"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#0E1629"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Primary (continue) button style -->
    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
      <Setter Property="Background"   Value="#C9A94F"/>
      <Setter Property="Foreground"   Value="#0E1629"/>
      <Setter Property="BorderBrush"  Value="#C9A94F"/>
      <Setter Property="FontWeight"   Value="SemiBold"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#D4B96A"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#B8923C"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Exit button style (red tint) -->
    <Style x:Key="ExitButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
      <Setter Property="BorderBrush" Value="#EF5350"/>
      <Setter Property="Foreground"  Value="#EF5350"/>
    </Style>
  </Window.Resources>

  <!-- Outer border matching splash / app chrome -->
  <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
          Background="#0E1629">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>   <!-- Header -->
        <RowDefinition Height="*"/>      <!-- Issue list -->
        <RowDefinition Height="Auto"/>   <!-- Buttons -->
      </Grid.RowDefinitions>

      <!-- ── Header ────────────────────────────────────────────────────────── -->
      <Border Grid.Row="0" Background="#1A2340"
              BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
              Padding="20,14">
        <StackPanel>
          <TextBlock Text="⚖ Factum IL — מצב שחזור"
                     FontSize="20" FontFamily="Georgia"
                     Foreground="{StaticResource GoldBrush}"
                     FontWeight="Bold"/>
          <TextBlock Text="נמצאו בעיות במהלך האתחול. עיין ברשימה למטה לפני שתמשיך."
                     FontSize="11" Foreground="{StaticResource LightTextBrush}"
                     Opacity="0.7" Margin="0,4,0,0"
                     FontFamily="Segoe UI"/>
        </StackPanel>
      </Border>

      <!-- ── Issue list ─────────────────────────────────────────────────────── -->
      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                    Margin="16,12,16,8">
        <StackPanel x:Name="IssuePanel" Orientation="Vertical"/>
      </ScrollViewer>

      <!-- ── Action buttons ─────────────────────────────────────────────────── -->
      <Border Grid.Row="2" Background="#1A2340"
              BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
              Padding="16,12">
        <WrapPanel HorizontalAlignment="Right" FlowDirection="RightToLeft">
          <Button x:Name="ContinueButton"
                  Style="{StaticResource PrimaryButton}"
                  Content="המשך בכל זאת"
                  Click="ContinueButton_Click"
                  Margin="0,0,0,0"/>
          <Button x:Name="RepairButton"
                  Style="{StaticResource ActionButton}"
                  Content="תקן התקנה"
                  Click="RepairButton_Click"/>
          <Button x:Name="BundleButton"
                  Style="{StaticResource ActionButton}"
                  Content="ייצא חבילת תמיכה"
                  Click="BundleButton_Click"/>
          <Button x:Name="LogsButton"
                  Style="{StaticResource ActionButton}"
                  Content="פתח תיקיית לוגים"
                  Click="LogsButton_Click"/>
          <Button x:Name="ExitButton"
                  Style="{StaticResource ExitButton}"
                  Content="צא"
                  Click="ExitButton_Click"/>
        </WrapPanel>
      </Border>
    </Grid>
  </Border>
</Window>
