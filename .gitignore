node_modules/
dist/
build/
.turbo/
*.tsbuildinfo

# Secrets — never commit
.env
.env.local
.env.*.local
*.key
*.pem
*.p12
*.pfx

# Installer staging artifacts (generated by Build-DistPackage.ps1)
dist-package/
FactumIL_V13_Installer.exe

# Runtime data (SQLite, Evidence Locker, downloaded binaries)
_data/
_evidence/

# User-supplied legal extension files (user places licensed regulation text here)
# The directory itself (.gitkeep) IS tracked; the user's content is not.
powershell/lib/User_Extensions/*
!powershell/lib/User_Extensions/.gitkeep
tools/whisper-fast.exe
tools/ffmpeg.exe
tools/OllamaSetup.exe

# SQLite databases (generated at runtime)
*.db
*.db-wal
*.db-shm

# Logs (generated at runtime)
logs/*.log
logs/*.jsonl

# OS
.DS_Store
Thumbs.db
desktop.ini

# C# build artifacts
apps/desktop/bin/
apps/desktop/obj/
FactumIL.Desktop/bin/
FactumIL.Desktop/obj/

# Installer staging (generated by publish.ps1)
FactumIL_Dist/

# IDE
.vscode/settings.json
.idea/
*.suo
*.user

# PowerShell
*.ps1xml~

# Test artifacts
coverage/
playwright-report/
test-results/

# Claude Code internal state
.claude/

# CI error report (generated by ci-error-formatter.mjs)
_ci-errors.json

# Bundled legislation corpus — large (laws + per-section embedding vectors).
# Generated by `pnpm ingest-knesset-odata`; distributed as a release asset, not committed.
assets/legal-corpus/*.jsonl
assets/legal-corpus/*.jsonl.gz
assets/legal-corpus/*.jsonl.gz.tmp
assets/legal-corpus/corpus-manifest.json
assets/legal-corpus/batches/*.jsonl.gz
