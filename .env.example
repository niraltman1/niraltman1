# Factum-IL — Environment Variables
# Copy this file to .env and fill in the values.
# All AI runs locally — no data leaves the machine.

# API server port (default: 3001, auto-increments if busy)
PORT=3001

# Ollama local endpoint — never point this to a remote server
OLLAMA_BASE_URL=http://127.0.0.1:11434

# SQLite database path
# Windows default: %APPDATA%\FactumIL\factum-il.db
# Linux/dev default: _data/factum-il.db
FACTUM_IL_DB_PATH=_data/factum-il.db

# Node environment (development | production)
NODE_ENV=development

# Session TTL in hours (default: 24)
SESSION_TTL_HOURS=24

# Default admin credentials — CHANGE IMMEDIATELY AFTER FIRST LOGIN
FACTUM_IL_ADMIN_USER=admin
FACTUM_IL_ADMIN_PASS=changeme

# CORS allowed origins (comma-separated, defaults to localhost only)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:3001

# Academic hub root path (optional — enables academic media pipeline)
# ACADEMIC_ROOT=C:\FactumIL\Academic

# Gmail OAuth (optional — enables Gmail integration)
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REDIRECT_URI=http://localhost:3001/api/gmail/callback

# Log level (ERROR | WARN | INFO | DEBUG, default: INFO)
# LOG_LEVEL=INFO
