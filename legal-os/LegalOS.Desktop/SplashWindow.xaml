<Window x:Class="FactumIL.Desktop.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Factum IL" Height="280" Width="480"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Topmost="True">
  <Border Background="#0E1629" CornerRadius="12"
          BorderBrush="#C9A94F" BorderThickness="1">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
      <TextBlock Text="⚖ Factum IL" FontSize="32" FontFamily="Georgia"
                 Foreground="#C9A94F" HorizontalAlignment="Center" />
      <TextBlock Text="Altman Law Firm · V13"
                 FontSize="13" Foreground="#E8D9B5" Opacity="0.6"
                 HorizontalAlignment="Center" Margin="0,6,0,24" />
      <ProgressBar x:Name="ProgressBar" Height="4" Width="300"
                   IsIndeterminate="True"
                   Foreground="#C9A94F" Background="#1A2340" />
      <TextBlock x:Name="StatusText" Text="מפעיל שרת API…"
                 FontSize="11" Foreground="#E8D9B5" Opacity="0.5"
                 HorizontalAlignment="Center" Margin="0,14,0,0"
                 FontFamily="Segoe UI" />
    </StackPanel>
  </Border>
</Window>
