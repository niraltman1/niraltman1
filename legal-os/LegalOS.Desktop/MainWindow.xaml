<Window x:Class="FactumIL.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="Factum IL V13 — Altman Law Firm"
        Height="900" Width="1440"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#0E1629">

  <Window.Resources>
    <ContextMenu x:Key="TrayMenu">
      <MenuItem Header="פתח Factum IL"      Click="TrayMenu_Open"   FontFamily="Segoe UI" />
      <MenuItem Header="הפעל שוב שרת API" Click="TrayMenu_Restart" FontFamily="Segoe UI" />
      <Separator />
      <MenuItem Header="סגור"              Click="TrayMenu_Exit"   FontFamily="Segoe UI" />
    </ContextMenu>
  </Window.Resources>

  <Grid>
    <!-- Tray icon -->
    <tb:TaskbarIcon x:Name="TrayIcon"
                    IconSource="/Resources/icon.ico"
                    ToolTipText="Factum IL V13"
                    ContextMenu="{StaticResource TrayMenu}"
                    TrayMouseDoubleClick="TrayIcon_DoubleClick" />

    <!-- WebView2 fills entire window -->
    <wv2:WebView2 x:Name="WebView"
                  Source="http://localhost:3001"
                  Margin="0" />
  </Grid>
</Window>
