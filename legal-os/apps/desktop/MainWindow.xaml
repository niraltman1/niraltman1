<Window x:Class="LegalOS.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Legal-OS | אלטמן משרד עורכי דין"
        Icon="Resources/icon.ico"
        Height="920" Width="1480"
        WindowState="Maximized"
        Background="#111827">

    <Grid>
        <!-- Splash / loading overlay — visible until API is ready -->
        <Grid x:Name="loadingGrid" Background="#111827" Panel.ZIndex="10">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Legal-OS"
                           FontSize="42" FontWeight="Bold"
                           Foreground="#C9A84C"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="אלטמן משרד עורכי דין — סדר 2026"
                           FontSize="17"
                           Foreground="#94A3B8"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"
                           FlowDirection="RightToLeft"/>
                <TextBlock x:Name="loadingStatus"
                           Text="מאתחל..."
                           FontSize="14"
                           Foreground="#64748B"
                           HorizontalAlignment="Center"
                           Margin="0,40,0,0"/>
            </StackPanel>
        </Grid>

        <!-- WebView2 — hidden until ready -->
        <wv2:WebView2 x:Name="webView" Visibility="Collapsed"/>
    </Grid>
</Window>
