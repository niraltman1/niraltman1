{
  "name": "factum-il",
  "version": "1.0.0",
  "private": true,
  "description": "Local-first document management and CRM operating system for Israeli boutique law firms",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,ui -c cyan,magenta \"pnpm --filter @factum-il/api dev\" \"pnpm --filter dashboard dev\"",
    "dev:win": "concurrently -n api,ui,watch -c cyan,magenta,yellow \"pnpm --filter @factum-il/api dev\" \"pnpm --filter dashboard dev\" \"pwsh -NoProfile -File powershell/scripts/Start-FileWatcher.ps1\"",
    "dev:ui": "pnpm --filter dashboard dev",
    "dev:api": "pnpm --filter @factum-il/api dev",
    "dev:watch": "pwsh -NoProfile -File powershell/scripts/Start-FileWatcher.ps1",
    "build": "pnpm --filter dashboard build",
    "build:all": "pnpm --filter @factum-il/api build && pnpm --filter dashboard build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:logic": "pnpm -r test",
    "test:chaos": "pnpm -r exec -- vitest run --reporter=verbose --testNamePattern='Chaos' --passWithNoTests",
    "test:env": "pnpm --filter @factum-il/api vitest run -- src/routes/__tests__/setup.test.ts --reporter=verbose",
    "test:unit": "pnpm --filter dashboard vitest run",
    "lint": "pnpm -r lint",
    "ingest-registry": "node tools/ingest-legal-sources.mjs",
    "build:installer": "powershell -ExecutionPolicy Bypass -File publish.ps1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^3.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.4.0",
  "pnpm": {
    "overrides": {
      "better-sqlite3": "^11.0.0",
      "esbuild@<=0.24.2": ">=0.25.0",
      "vite@<=6.4.1": ">=6.4.2",
      "vitest": "^3.0.0"
    }
  }
}
